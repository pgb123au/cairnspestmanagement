---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Free Pest Control Quote | Cairns Pest Management"
  description="Get a free pest control quote in Cairns — general pest, termites, cockroaches, ants, rodents or commercial. Licensed, APVMA-registered, recurring plans. Same/next-day available."
  canonical="https://cairnspestmanagement.com.au/quote/">

  <section class="hero" style="padding: 2.5rem 0 3rem;">
    <div class="hero-inner">
      <span class="hero-eyebrow">Free Quote</span>
      <h1>Get your free pest control quote.</h1>
      <p class="hero-sub">
        Tell us what you are dealing with &mdash; cockroaches, ants, rodents, a
        termite inspection, or a commercial program &mdash; and we will get back to
        you with a quote. Most general pest jobs are booked within a day or two,
        and urgent or pre-purchase work we will prioritise. Free, no obligation.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="form-wrap">
        <div class="form-card">
          <form name="quote" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" action="/thanks/">
            <input type="hidden" name="form-name" value="quote" />
            <p style="display:none;"><label>Don&rsquo;t fill this out: <input name="bot-field" /></label></p>

            <label for="name">Your name</label>
            <input id="name" name="name" type="text" autocomplete="name" required />

            <label for="phone">Phone number</label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" required placeholder="04xx xxx xxx" />

            <label for="email">Email</label>
            <input id="email" name="email" type="email" autocomplete="email" required />

            <label for="suburb">Suburb / postcode</label>
            <input id="suburb" name="suburb" type="text" autocomplete="address-level2" required placeholder="e.g. Edmonton 4869, Redlynch 4870, Trinity Beach 4879" />

            <label for="service-type">What do you need?</label>
            <select id="service-type" name="service-type">
              <option value="not-sure">Not sure &mdash; want a recommendation</option>
              <option value="general-pest">General pest control (cockroaches, ants, spiders)</option>
              <option value="cockroaches-ants">Cockroaches &amp; ants</option>
              <option value="rodents">Rats &amp; mice (rodent control)</option>
              <option value="termite-inspection">Termite inspection (AS 3660)</option>
              <option value="termite-treatment">Termite treatment / barrier</option>
              <option value="pre-purchase">Pre-purchase timber pest inspection (settlement)</option>
              <option value="commercial">Commercial / food premises program</option>
              <option value="recurring-plan">Recurring / ongoing protection plan</option>
            </select>

            <label for="property-type">Property type</label>
            <select id="property-type" name="property-type">
              <option value="house">Free-standing house</option>
              <option value="townhouse">Townhouse</option>
              <option value="apartment">Apartment / unit</option>
              <option value="holiday-let">Holiday let / short-term rental</option>
              <option value="commercial">Commercial / business</option>
              <option value="body-corporate">Body-corporate / strata complex</option>
              <option value="acreage">Acreage / rural-residential</option>
              <option value="other">Other</option>
            </select>

            <label for="age">Approximate age</label>
            <select id="age" name="age">
              <option value="not-sure">Not sure</option>
              <option value="pre-1980">Pre-1980 (very old)</option>
              <option value="1980-2000">1980&ndash;2000</option>
              <option value="2000-2015">2000&ndash;2015</option>
              <option value="2015-plus">Post-2015 (modern)</option>
              <option value="under-construction">Under construction</option>
            </select>

            <label for="urgency">Urgency</label>
            <select id="urgency" name="urgency">
              <option value="asap">URGENT &mdash; infestation right now</option>
              <option value="settlement">Settlement deadline (this week)</option>
              <option value="2-weeks">Within 2 weeks</option>
              <option value="month">Within a month</option>
              <option value="schedule">Setting up a regular plan</option>
              <option value="quote-only">Quote only, no urgency</option>
            </select>

            <label for="risk-zone">Property location</label>
            <select id="risk-zone" name="risk-zone">
              <option value="standard">Standard suburban block</option>
              <option value="northern-beaches">Northern beaches (Trinity Beach, Palm Cove, Clifton Beach)</option>
              <option value="rainforest-valley">Rainforest valley (Redlynch, Brinsmead, Whitfield)</option>
              <option value="growth-corridor">Southern growth corridor (Edmonton, Mount Sheridan, Gordonvale)</option>
              <option value="inner-city">Inner city / commercial (Cairns City, Earlville)</option>
              <option value="acreage-bushland">Acreage / bushland edge</option>
              <option value="not-sure">Not sure</option>
            </select>

            <label for="message">Any details? (optional)</label>
            <textarea id="message" name="message" rows="4" placeholder="Which pest, where you're seeing it, how long it's been going on, any prior treatment, settlement or trading-hours details, etc."></textarea>

            <button class="btn btn-primary btn-block" type="submit">Send my quote request</button>

            <p style="margin-top: 1rem; font-size: 0.85rem; color: var(--c-muted);">We reply within 1 business day. Free, no obligation. Urgent calls answered Mon&ndash;Sat 7am&ndash;5pm.</p>
          </form>
        </div>

        <aside class="form-aside">
          <h3>Prefer to talk?</h3>

          <div class="info-row">
            <span aria-hidden="true" style="font-size:1.5rem; line-height:1;">&#9742;</span>
            <div>
              <strong>Phone</strong>
              <a class="ph-cta" href="/quote/" aria-label="Call us"><span aria-hidden="true">&#9742;</span> <span class="ph-text">Tap to call</span></a>
              <p style="font-size:0.85rem; color:var(--c-muted); margin:0;">Mon&ndash;Sat 7am&ndash;5pm AEST</p>
            </div>
          </div>

          <div class="info-row">
            <span aria-hidden="true" style="font-size:1.5rem; line-height:1;">&#9978;</span>
            <div>
              <strong>Service area</strong>
              <p style="margin:0;">Cairns &amp; the Cairns region &mdash; Edmonton, Smithfield, Redlynch, Trinity Beach, Earlville, Cairns City, Gordonvale, Palm Cove and the northern beaches.</p>
            </div>
          </div>

          <div class="info-row">
            <span aria-hidden="true" style="font-size:1.5rem; line-height:1;">&#10004;</span>
            <div>
              <strong>What you&rsquo;ll get</strong>
              <ul style="margin:0.4rem 0 0; padding-left:1rem; font-size:0.95rem; color:var(--c-text);">
                <li>Free phone consultation</li>
                <li>Fast booking &mdash; most jobs within a day or two</li>
                <li>Licensed technician, APVMA-registered products</li>
                <li>12-month warranty on general pest work</li>
                <li>Recurring plans for year-round protection</li>
                <li>AEPMA member, AS 3660 termite work</li>
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
